// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "diff_view_style": "unified",
    "file_finder": {},
    "search": {
        "include_ignored": true
    },
    "show_wrap_guides": true,
    "wrap_guides": [80, 100],
    "minimap": {
        "display_in": "active_editor",
        "show": "auto"
    },
    "preferred_line_length": 100,
    "restore_on_startup": "launchpad",
    "tabs": {
        "file_icons": true,
        "git_status": true
    },
    "agent_servers": {
        "claude-acp": {
            "type": "registry"
        }
    },
    "proxy": "",
    "agent": {
        "sidebar_side": "left",
        "favorite_models": [],
        "model_parameters": []
    },
    "wsl_connections": [
        {
            "distro_name": "Ubuntu",
            "user": null,
            "projects": [
                {
                    "paths": ["/home/mvd/git/ascend-design-docs"]
                },
                {
                    "paths": ["/home/mvd/git/environment-setup"]
                },
                {
                    "paths": ["/home/mvd/git/hestia"]
                },
                {
                    "paths": ["/home/mvd/git/traverse"]
                }
            ]
        }
    ],
    "telemetry": {
        "diagnostics": false,
        "metrics": false
    },

    // Panels and UI
    // ------------------------------------------------------------------------

    "vim_mode": true,
    "icon_theme": "Catppuccin Frappé",
    "base_keymap": "VSCode",
    "ui_font_size": 16.0,
    "buffer_font_family": ".ZedMono",
    "buffer_font_size": 13.0,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "Ayu Dark"
    },
    "git_panel": {
        "dock": "left"
    },
    "outline_panel": {
        "dock": "left"
    },
    "project_panel": {
        "dock": "left"
    },

    // Languages
    // ------------------------------------------------------------------------

    "languages": {
        "JSON": {
            "tab_size": 2
        },
        "Python": {
            // "code_actions_on_format": {
            //     "source.organizeImports.ruff": true
            // },
            "language_servers": ["ruff", "ty", "!basedpyright"],
            "formatter": {
                "language_server": {
                    "name": "ruff"
                }
            }
        },
        "YAML": {
            "formatter": "language_server",
            "tab_size": 2
        }
    },

    // Language servers
    // ------------------------------------------------------------------------

    "lsp": {
        "basedpyright": {
            "settings": {
                "basedpyright.analysis": {
                    "diagnosticSeverityOverrides": {
                        "reportAny": false,
                        "reportImplicitStringConcatenation": false,
                        "reportMissingTypeStubs": false,
                        "reportUnknownArgumentType": false,
                        "reportUnknownMemberType": false,
                        "reprotUnknownVariableType": false,
                        "reportUnusedCallResult": false
                    }
                }
            }
        },
        "ruff": {
            "initialization_options": {
                "settings": {
                    "lint": { "preview": true },
                    "format": { "preview": true }
                }
            }
        }
    },

    // Extensions
    // ------------------------------------------------------------------------

    "auto_install_extensions": {
        "Catppuccin Icons": true,
        "editorconfig": true,
        "Git Firefly": true,
        "html": true,
        "ini": true,
        "sql": true,
        "terraform": true,
        "toml": true
    }
}
